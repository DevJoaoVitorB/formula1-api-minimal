{
    "compilerOptions": {
        // Language and Environment Settings
        "lib": [
            "es2024",
            "ESNext.Array",
            "ESNext.Collection",
            "ESNext.Error",
            "ESNext.Iterator",
            "ESNext.Promise"
        ],
        "module": "nodenext",
        "target": "es2024",
        "moduleResolution": "node16",

        // Types
        "types": ["node"],

        // Paths
        "rootDir": "./src",
        "outDir": "./dist",
        "paths": {
            "@/*": ["./src/*"]
        },

        // Strictness
        "strict": true,

        // Interop and Build
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,

        // DX - Developer Experience
        "sourceMap": true,
        "removeComments": true
    },
    "include": ["src"],
    "exclude": ["node_modules", "dist"]
}
